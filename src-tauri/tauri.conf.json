{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steek",
  "version": "0.1.0",
  "identifier": "be.borduurweelde.steek",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Steek - Borduurweelde",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Borduurweelde",
    "copyright": "© 2025 Borduurweelde"
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://bitbucket.org/p_heylen/steek/raw/HEAD/releases/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preloadConnections": ["sqlite:steek.db"]
    }
  }
}
